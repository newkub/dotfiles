[
    // Toggle terminal
    {
        "key": "ctrl+m",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    // Open Problems panel
    {
        "key": "ctrl+shift+p",
        "command": "workbench.actions.view.problems"
    },
    // Kill terminal (when terminal focused)
    {
        "key": "ctrl+w",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus"
    },
    // Focus next terminal pane (when terminal focused)
    {
        "key": "shift+tab",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus"
    },
    // Open run task
    {
        "key": "ctrl+shift+t",
        "command": "workbench.action.tasks.runTask"
    },
    // Open folder (when not in terminal)
    {
        "key": "ctrl+o",
        "command": "workbench.action.files.openFolder",
        "when": "!terminalFocus"
    },
    // Open new terminal tab
    {
        "key": "ctrl+t",
        "command": "workbench.action.terminal.new"
    },
    // Rename file
    {
        "key": "f2",
        "command": "renameFile"
    },
    // Focus source control
    {
        "key": "alt+g",
        "command": "workbench.scm.focus"
    },
    // Close all editor groups
    {
        "key": "alt+w",
        "command": "workbench.action.closeAllEditors"
    },
    {
        "key": "ctrl+w",
        "command": "workbench.action.closeAllEditors"
    },
    {
        "key": "ctrl+shift+t",
        "command": "-workbench.action.reopenClosedEditor"
    },
    {
        "key": "ctrl+shift+right",
        "command": "workbench.action.terminal.split",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+shift+left",
        "command": "workbench.action.terminal.split",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.focusActiveEditorGroup"
    },
    {
        "key": "ctrl+l",
        "command": "windsurf.cascadeViewContainerId"
    },
    {
        "key": "ctrl+l",
        "command": "windsurf.prioritized.chat.open"
    },
    {
        "key": "ctrl+shift+s",
        "command": "windsurf.cascade.toggleModelSelector",
        "when": "windsurf.cascadePanel.focused"
    },
    {
        "key": "ctrl+shift+r",
        "command": "npm.focus"
    },
    {
        "key": "ctrl+t",
        "command": "vscode-browser-tab.open",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "ctrl+shift+e",
        "command": "-workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "ctrl+shift+c",
        "command": "copyFilePath",
        "when": "filesExplorerFocus || editorFocus"
    },
    {
        "key": "shift+alt+c",
        "command": "-copyFilePath",
        "when": "editorFocus"
    },
    {
        "key": "f11",
        "command": "workbench.action.toggleZenMode",
        "when": "!isAuxiliaryWindowFocusedContext"
    },
    {
        "key": "ctrl+k z",
        "command": "-workbench.action.toggleZenMode",
        "when": "!isAuxiliaryWindowFocusedContext"
    },
]