{
  "mcpServers": {
    "chrome-devtools": {
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "command": "bunx"
    },
    "crw": {
      "command": "bunx",
      "args": ["crw-mcp"]
    },
    "deepwiki": {
      "registry": "io.windsurf/deepwiki",
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "grep": {
      "url": "https://mcp.grep.app"
    },
    "io.windsurf/cloudflare-docs": {
      "registry": "io.windsurf/cloudflare-docs",
      "serverUrl": "https://docs.mcp.cloudflare.com/mcp"
    },
    "io.windsurf/deepwiki": {
      "registry": "io.windsurf/deepwiki",
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "io.windsurf/github-mcp-server": {
      "registry": "io.windsurf/github-mcp-server",
      "url": "https://api.githubcopilot.com/mcp"
    },
    "linear": {
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "command": "bunx"
    },
    "mise": {
      "args": [
        "-y"
      ],
      "command": "mise",
      "disabled": true,
      "env": {
        "MISE_EXPERIMENTAL": "1"
      }
    },
    "moon": {
      "command": "moon",
      "disabled": false,
      "env": {
        "MOON_WORKSPACE_ROOT": "/"
      }
    },
    "next-devtools": {
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ],
      "command": "bunx"
    },
    "nuxt": {
      "args": [
        "mcp"
      ],
      "command": "nuxt"
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "bunx"
    },
    "stripe": {
      "url": "https://mcp.stripe.com/mcp"
    },
    "vueuse": {
      "args": [
        "vueuse-mcp"
      ],
      "command": "bunx"
    },
    "wezterm": {
      "args": [
        "mcp-server-wezterm-rs"
      ],
      "command": "uvx"
    }
  }
}