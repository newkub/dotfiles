{
  "mcpServers": {
    "better-fullstack": {
      "args": [
        "-y",
        "create-better-fullstack",
        "mcp"
      ],
      "command": "bunx",
      "disabled": true
    },
    "chrome-devtools": {
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "command": "bunx",
      "disabled": true
    },
    /*
    "clickup": {
      "disabled": true,
      "serverUrl": "https://mcp.clickup.com/mcp"
    },*/
    "crw": {
      "args": [
        "crw-mcp"
      ],
      "command": "bunx",
      "disabled": true,
      "env": {
        "CRW_BROWSER_PATH": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
      }
    },
    "deepwiki": {
      "registry": "io.windsurf/deepwiki",
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "grep": {
      "disabled": true,
      "url": "https://mcp.grep.app"
    },
    "io.windsurf/cloudflare-docs": {
      "registry": "io.windsurf/cloudflare-docs",
      "serverUrl": "https://docs.mcp.cloudflare.com/mcp"
    },
    "io.windsurf/deepwiki": {
      "registry": "io.windsurf/deepwiki",
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "io.windsurf/github-mcp-server": {
      "registry": "io.windsurf/github-mcp-server",
      "url": "https://api.githubcopilot.com/mcp"
    },
    "linear": {
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "command": "bunx",
      "disabled": true
    },
    "mise": {
      "args": [
        "-y"
      ],
      "command": "mise",
      "disabled": true,
      "env": {
        "MISE_EXPERIMENTAL": "1"
      }
    },
    "moon": {
      "command": "moon",
      "disabled": true,
      "env": {
        "MOON_WORKSPACE_ROOT": "/"
      }
    },
    "next-devtools": {
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ],
      "command": "bunx",
      "disabled": true
    },
    "nuxt": {
      "args": [
        "mcp"
      ],
      "command": "nuxt",
      "disabled": true
    },
    "raindrop": {
      "disabled": true,
      "serverUrl": "https://api.raindrop.io/rest/v2/ai/mcp"
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "bunx",
      "disabled": true
    },
    "stripe": {
      "disabled": true,
      "url": "https://mcp.stripe.com/mcp"
    },
    "vueuse": {
      "args": [
        "vueuse-mcp"
      ],
      "command": "bunx"
    },
    "wezterm": {
      "args": [
        "mcp-server-wezterm-rs"
      ],
      "command": "uvx",
      "disabled": true
    }
  }
}