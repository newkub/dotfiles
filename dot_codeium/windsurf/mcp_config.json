{
  "mcpServers": {
    "chrome-devtools": {
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "command": "bunx"
    },
    "deepwiki": {
      "registry": "io.windsurf/deepwiki",
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "grep": {
      "url": "https://mcp.grep.app"
    },
    "io.windsurf/cloudflare-docs": {
      "registry": "io.windsurf/cloudflare-docs",
      "serverUrl": "https://docs.mcp.cloudflare.com/mcp"
    },
    "io.windsurf/deepwiki": {
      "registry": "io.windsurf/deepwiki",
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "io.windsurf/github-mcp-server": {
      "registry": "io.windsurf/github-mcp-server",
      "url": "https://api.githubcopilot.com/mcp"
    },
    /*
    "io.windsurf/vercel": {
      "disabled": true,
      "registry": "io.windsurf/vercel",
      "url": "https://mcp.vercel.com"
    },*/
    "linear": {
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "command": "bunx"
    },
    /*
    "mcpmarket": {
      "disabled": true,
      "serverUrl": "https://link.mcpmarket.com/newkubise/toolkits/mcpmarket/mcp"
    },*/
    "mise": {
      "args": [
        "-y"
      ],
      "command": "mise",
      "env": {
        "MISE_EXPERIMENTAL": "1"
      }
    },
    "moon": {
      "command": "moon",
      "env": {
        "MOON_WORKSPACE_ROOT": "/"
      }
    },
    "next-devtools": {
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ],
      "command": "bunx"
    },
    "nuxt": {
      "command": "bunx"
    },
    "nuxt-docs": {
      "serverUrl": "https://nuxt.com/mcp"
    },
    "raindrop": {
      "disabled": false,
      "serverUrl": "https://api.raindrop.io/rest/v2/ai/mcp"
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "bunx"
    },
    "stripe": {
      "url": "https://mcp.stripe.com/mcp"
    },
    "wezterm-mcp": {
      "command": "bunx",
      "disabled": true
    }
  }
}