{
  "mcpServers": {
    "cloudflare-docs": {
      "args": [
        "mcp-remote",
        "https://docs.mcp.cloudflare.com/mcp"
      ],
      "command": "bunx",
      "disabled": true
    },
    "context7": {
      "disabled": false,
      "headers": {
        "CONTEXT7_API_KEY": "{CONTEXT7_API_KEY}"
      },
      "serverUrl": "https://mcp.context7.com/mcp"
    },
    "deepwiki": {
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "io.windsurf/cloudflare-docs": {
      "registry": "io.windsurf/cloudflare-docs",
      "url": "https://docs.mcp.cloudflare.com/mcp"
    },
    "io.windsurf/deepwiki": {
      "registry": "io.windsurf/deepwiki",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "linear": {
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "command": "bunx"
    },
    "moon": {
      "args": [
        "mcp"
      ],
      "command": "moon",
      "env": {
        "MOON_WORKSPACE_ROOT": "/"
      }
    },
    "nuxt": {
      "serverUrl": "http://localhost:3000/__mcp/sse"
    },
    "nuxt-docs": {
      "serverUrl": "https://nuxt.com/mcp"
    },
    "wezterm-mcp": {
      "args": [
        "-y",
        "wezterm-mcp"
      ],
      "command": "bunx"
    }
  }
}